{
  "name": "hotel-search",
  "version": "1.0.0",
  "description": "IHG Hotel Search Application",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "start:mobile": "ng serve --host 0.0.0.0 --disable-host-check --proxy-config proxy.conf.json",
    "start:api": "node server.js",
    "start:dev": "concurrently \"npm run start:api\" \"npm run start\"",
    "start:dev:mobile": "concurrently --kill-others \"npm run start:api\" \"npm run start:mobile\"",
    "build": "ng build --configuration production",
    "build:stats": "ng build --configuration production --stats-json",
    "analyze": "webpack-bundle-analyzer dist/hotel-search/stats.json",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@asymmetrik/ngx-leaflet": "^16.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "flatpickr": "^4.6.13",
    "leaflet": "^1.9.4",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "^0.14.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular/cli": "^17.3.17",
    "@angular/compiler-cli": "^17.3.0",
    "@types/jest": "^29.5.12",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20.11.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "fast-check": "^3.15.1",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.0.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.3.3"
  }
}
