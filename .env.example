# Google Gemini AI API Key
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Password Protection (set to 'true' to enable password gate)
# This will show a password screen before accessing the app
PASSWORD_PROTECTED=false

# App Password (only used if PASSWORD_PROTECTED=true)
# Users must enter this password to access the application
APP_PASSWORD=your_secure_password_here

# Note: For Vercel deployment, set these in Vercel dashboard or CLI
# vercel env add GEMINI_API_KEY
# vercel env add PASSWORD_PROTECTED
# vercel env add APP_PASSWORD
