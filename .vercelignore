# Source files (only deploy built files)
src/
*.ts
!api/**/*.ts

# Development files
node_modules/
.angular/
.vscode/
.idea/

# Testing
coverage/
*.spec.ts
*.spec.js
jest.config.js
tsconfig.spec.json

# Documentation
README.md
*.md
!vercel.json

# Environment files (use Vercel env vars instead)
.env
.env.local
.env.*.local

# Build artifacts not needed
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Development server
server.js
proxy.conf.json

# Git
.git/
.gitignore

# macOS
.DS_Store

# Angular cache
.angular/cache/
